---
// Visual breadcrumb component. Also handy as input to BreadcrumbList JSON-LD
// which should be rendered separately in the page's <head> slot.

export interface Crumb {
  name: string;
  href?: string; // last crumb usually has no href (current page)
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-1.5 text-slate-600 dark:text-slate-400">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-slate-400">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        )}
        {crumb.href ? (
          <a
            href={crumb.href}
            class="rounded transition-colors hover:text-brand-700 dark:hover:text-brand-400"
          >
            {crumb.name}
          </a>
        ) : (
          <span class="font-medium text-slate-900 dark:text-white" aria-current="page">
            {crumb.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

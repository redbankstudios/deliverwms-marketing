---
/**
 * Reusable FAQPage JSON-LD. Already inlined on /pricing but reused for
 * blog posts (which often have an FAQ section).
 */

export interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

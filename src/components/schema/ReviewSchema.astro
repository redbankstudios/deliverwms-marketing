---
/**
 * Review + AggregateRating JSON-LD attached to the SoftwareApplication entity.
 *
 * Skips emission entirely if no real testimonials are present, so the
 * placeholder cards on the homepage never end up in structured data.
 */

import { realTestimonials } from '@/data/testimonials';
import { SITE_URL, BRAND } from '@/lib/brand';

const real = realTestimonials();
const hasReviews = real.length > 0;

const reviews = real.map((t) => ({
  '@type': 'Review',
  reviewBody: t.quote,
  author: { '@type': 'Person', name: t.authorName, ...(t.authorTitle ? { jobTitle: t.authorTitle } : {}) },
  ...(t.companyName ? { publisher: { '@type': 'Organization', name: t.companyName } } : {}),
  ...(t.date ? { datePublished: t.date } : {}),
  reviewRating: {
    '@type': 'Rating',
    ratingValue: String(t.rating ?? 5),
    bestRating: '5',
    worstRating: '1',
  },
  itemReviewed: { '@type': 'SoftwareApplication', name: BRAND.name, url: SITE_URL },
}));

const avgRating =
  real.length > 0
    ? real.reduce((sum, t) => sum + (t.rating ?? 5), 0) / real.length
    : 0;

const aggregateSchema = hasReviews
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: BRAND.name,
      url: SITE_URL,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: avgRating.toFixed(1),
        reviewCount: real.length,
        bestRating: '5',
        worstRating: '1',
      },
      review: reviews,
    }
  : null;
---

{aggregateSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />
)}

---
/**
 * Article JSON-LD for blog posts.
 *
 * Pair with Person schema for the author and BreadcrumbList for the trail.
 * datePublished + dateModified are critical freshness signals for both Google
 * and generative AI engines (Perplexity etc. preferentially cite recent pages).
 */

import { SITE_URL, BRAND } from '@/lib/brand';

interface Props {
  url: string;
  title: string;
  description: string;
  image: string;
  datePublished: Date | string;
  dateModified?: Date | string;
  authorId: string; // @id pointing at the Person schema
  authorName: string;
  keywords?: string[];
  wordCount?: number;
  articleSection?: string;
}

const {
  url,
  title,
  description,
  image,
  datePublished,
  dateModified,
  authorId,
  authorName,
  keywords,
  wordCount,
  articleSection,
} = Astro.props;

const toIso = (d: Date | string) => (d instanceof Date ? d.toISOString() : new Date(d).toISOString());

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: [image],
  datePublished: toIso(datePublished),
  dateModified: toIso(dateModified ?? datePublished),
  author: {
    '@type': 'Person',
    '@id': authorId,
    name: authorName,
  },
  publisher: {
    '@type': 'Organization',
    name: BRAND.name,
    url: SITE_URL,
    logo: { '@type': 'ImageObject', url: BRAND.logo },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  ...(keywords && keywords.length ? { keywords: keywords.join(', ') } : {}),
  ...(wordCount ? { wordCount } : {}),
  ...(articleSection ? { articleSection } : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

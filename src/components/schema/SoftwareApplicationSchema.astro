---
/**
 * SoftwareApplication JSON-LD schema for the product itself.
 *
 * This is the schema that tells Google and AI engines: "this site represents
 * a real software product." It enables Product-style rich results, pricing
 * snippets, and feature listings in AI summaries.
 *
 * Mount on:
 *   - / (homepage) — primary
 *   - /features    — secondary
 *   - /pricing     — secondary, with offers populated
 */

import { SITE_URL, BRAND } from '@/lib/brand';

interface Offer {
  name: string;
  price: string; // numeric or 'Contact us'
  priceCurrency?: string;
  description?: string;
}

interface Props {
  /** Optional override; defaults to the standard product description. */
  description?: string;
  /** Optional pricing offers to attach (use on /pricing). */
  offers?: Offer[];
  /** Optional aggregate rating once you have reviews. */
  aggregateRating?: {
    ratingValue: number;
    reviewCount: number;
  };
  /** Featured screenshot URL. */
  screenshot?: string;
}

const {
  description = BRAND.description,
  offers,
  aggregateRating,
  screenshot = `${SITE_URL}/images/app-dashboard.webp`,
} = Astro.props;

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: BRAND.name,
  url: SITE_URL,
  description,
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'Warehouse Management Software',
  operatingSystem: 'Web, iOS, Android',
  // Browser-based + native mobile worker / driver apps.
  softwareVersion: '1.0',
  screenshot,
  publisher: {
    '@type': 'Organization',
    name: BRAND.name,
    url: SITE_URL,
    logo: BRAND.logo,
  },
};

if (offers && offers.length > 0) {
  schema.offers = {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '0',
    offerCount: offers.length,
    offers: offers.map((o) => ({
      '@type': 'Offer',
      name: o.name,
      price: o.price,
      priceCurrency: o.priceCurrency ?? 'USD',
      ...(o.description ? { description: o.description } : {}),
    })),
  };
}

if (aggregateRating) {
  schema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: aggregateRating.ratingValue,
    reviewCount: aggregateRating.reviewCount,
    bestRating: 5,
    worstRating: 1,
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

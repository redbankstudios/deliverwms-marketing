---
import { SOCIAL_PROFILES } from '@/lib/brand';

const productLinks = [
  { href: '/features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const solutionsLinks = [
  { href: '/features#3pl', label: '3PL Operators' },
  { href: '/features#ecommerce', label: 'eCommerce Brands' },
  { href: '/features#distributors', label: 'Distributors' },
  { href: '/features#last-mile', label: 'Last-Mile Delivery' },
];
const legalLinks = [
  { href: '/legal/privacy', label: 'Privacy Policy' },
  { href: '/legal/terms', label: 'Terms of Service' },
  { href: '/legal/msa', label: 'Master Services Agreement' },
  { href: '/legal/dpa', label: 'Data Processing Agreement' },
];

// Build the social-link list from whatever URLs are populated in brand.ts.
// Empty strings are filtered, so the section gracefully hides itself until
// at least one profile is live.
const socialLinks = [
  { href: SOCIAL_PROFILES.linkedin, label: 'LinkedIn', sr: 'Deliver WMS on LinkedIn' },
  { href: SOCIAL_PROFILES.twitter, label: 'X', sr: 'Deliver WMS on X' },
  { href: SOCIAL_PROFILES.github, label: 'GitHub', sr: 'Deliver WMS on GitHub' },
  { href: SOCIAL_PROFILES.youtube, label: 'YouTube', sr: 'Deliver WMS on YouTube' },
].filter((s) => s.href);

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50 py-12 dark:border-slate-800 dark:bg-slate-900/50">
  <div class="container-page">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 font-semibold text-slate-900 dark:text-white">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
              <path d="M3 7l9-4 9 4-9 4-9-4z" />
              <path d="M3 12l9 4 9-4" />
              <path d="M3 17l9 4 9-4" />
            </svg>
          </span>
          <span>Deliver WMS</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-slate-600 dark:text-slate-400">
          The all-in-one warehouse management and last-mile delivery platform for modern logistics operations.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Product</h3>
        <ul class="mt-4 space-y-2">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Solutions</h3>
        <ul class="mt-4 space-y-2">
          {solutionsLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Legal</h3>
        <ul class="mt-4 space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 text-sm text-slate-500 sm:flex-row dark:border-slate-800 dark:text-slate-500">
      <p>© {year} Deliver WMS. All rights reserved.</p>
      <div class="flex flex-col items-center gap-3 sm:flex-row sm:gap-5">
        {socialLinks.length > 0 && (
          <ul class="flex items-center gap-4">
            {socialLinks.map((s) => (
              <li>
                <a
                  href={s.href}
                  rel="noopener me"
                  target="_blank"
                  aria-label={s.sr}
                  class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white"
                >
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )}
        <p>
          <a href="mailto:hello@deliverwms.com" class="hover:text-slate-900 dark:hover:text-white">hello@deliverwms.com</a>
        </p>
      </div>
    </div>
  </div>
</footer>

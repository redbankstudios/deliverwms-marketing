---
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'privacy' },
      props: {
        title: 'Privacy Policy — Deliver WMS',
        description: 'How Deliver WMS collects, uses, and protects information.',
        heading: 'Privacy Policy',
      },
    },
    {
      params: { slug: 'terms' },
      props: {
        title: 'Terms of Service — Deliver WMS',
        description: 'The terms governing your use of the Deliver WMS platform.',
        heading: 'Terms of Service',
      },
    },
    {
      params: { slug: 'msa' },
      props: {
        title: 'Master Services Agreement — Deliver WMS',
        description: 'The Deliver WMS Master Services Agreement.',
        heading: 'Master Services Agreement',
      },
    },
    {
      params: { slug: 'dpa' },
      props: {
        title: 'Data Processing Agreement — Deliver WMS',
        description: 'The Deliver WMS Data Processing Agreement.',
        heading: 'Data Processing Agreement',
      },
    },
  ];
}

interface Props {
  title: string;
  description: string;
  heading: string;
}

const { title, description, heading } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="bg-white py-16 sm:py-20 dark:bg-slate-950">
    <div class="container-narrow">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{heading}</h1>
      <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
        Last updated: <time datetime="2026-05-11">May 11, 2026</time>
      </p>

      <div class="prose prose-slate mt-10 max-w-none dark:prose-invert">
        <p>
          <strong>[Operator: replace this placeholder with the actual {heading} content.]</strong>
        </p>
        <p>
          This is a placeholder legal page. To populate it, edit
          <code>src/pages/legal/[slug].astro</code> and add the actual policy text inside the
          <code>prose</code> div for the relevant slug. Until then, this page links from the footer
          but contains no enforceable terms.
        </p>
        <p>
          For questions about this document, contact us at
          <a href="mailto:hello@deliverwms.com">hello@deliverwms.com</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

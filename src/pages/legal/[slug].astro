---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import { SITE_URL } from '@/lib/brand';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('legal');
  return docs.map((doc) => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

interface Props { doc: CollectionEntry<'legal'>; }
const { doc } = Astro.props;
const { data, slug } = doc;
const { Content, headings } = await doc.render();

const pageUrl = `${SITE_URL}/legal/${slug}`;

// Filter to H2-level headings for the TOC — H3+ would crowd it.
const tocHeadings = headings.filter((h) => h.depth === 2);

const effective = data.effectiveDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updated = data.lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${data.title} — Deliver WMS`} description={data.description} canonical={pageUrl}>
  <BreadcrumbSchema
    slot="head"
    crumbs={[
      { name: 'Home', url: `${SITE_URL}/` },
      { name: 'Legal', url: `${SITE_URL}/legal/privacy` },
      { name: data.shortTitle, url: pageUrl },
    ]}
  />

  <!-- Header -->
  <section class="border-b border-slate-200 bg-white py-12 sm:py-16 dark:border-slate-800 dark:bg-slate-950">
    <div class="container-narrow">
      <Breadcrumb crumbs={[
        { name: 'Home', href: '/' },
        { name: 'Legal', href: '/legal/privacy' },
        { name: data.shortTitle },
      ]} />
      <h1 class="display mt-6 text-4xl font-bold tracking-tight sm:text-5xl">{data.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600 dark:text-slate-400">{data.summary}</p>
      <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
        <div>
          <dt class="inline font-semibold text-slate-700 dark:text-slate-300">Effective:</dt>
          <dd class="inline ml-1"><time datetime={data.effectiveDate.toISOString()}>{effective}</time></dd>
        </div>
        <div>
          <dt class="inline font-semibold text-slate-700 dark:text-slate-300">Last updated:</dt>
          <dd class="inline ml-1"><time datetime={data.lastUpdated.toISOString()}>{updated}</time></dd>
        </div>
        <div>
          <dt class="inline font-semibold text-slate-700 dark:text-slate-300">Version:</dt>
          <dd class="inline ml-1">{data.version}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Body with sidebar TOC -->
  <section class="bg-white py-12 sm:py-16 dark:bg-slate-950">
    <div class="container-narrow">
      <div class="grid gap-10 lg:grid-cols-[14rem_1fr]">
        <aside class="hidden lg:block">
          <nav aria-label="On this page" class="sticky top-24">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
              On this page
            </p>
            <ul class="mt-3 space-y-2 text-sm">
              {tocHeadings.map((h) => (
                <li>
                  <a href={`#${h.slug}`} class="text-slate-600 hover:text-brand-700 dark:text-slate-400 dark:hover:text-brand-400">
                    {h.text}
                  </a>
                </li>
              ))}
              <li class="border-t border-slate-200 pt-2 dark:border-slate-800">
                <a href="/legal/privacy" class="block text-xs text-slate-500 hover:text-brand-700 dark:text-slate-400 dark:hover:text-brand-400">All legal documents →</a>
              </li>
            </ul>
          </nav>
        </aside>

        <article class="prose prose-slate prose-lg max-w-none dark:prose-invert prose-headings:font-display prose-h2:mt-12 prose-h2:scroll-mt-24 prose-h3:scroll-mt-24 prose-a:text-brand-700 dark:prose-a:text-brand-400">
          <Content />

          <hr />
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Questions about this document? Email
            <a href="mailto:legal@deliverwms.com">legal@deliverwms.com</a> or
            <a href="/contact">contact us</a>.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

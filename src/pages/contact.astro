---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm';

const title = 'Contact Deliver WMS — Talk to Sales or Support';
const description =
  'Get in touch with Deliver WMS. Talk to sales about plans for your 3PL or warehouse, or reach support for help with your account.';

// ContactPage JSON-LD for entity clarity
const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: 'https://deliverwms.com/contact',
  about: {
    '@type': 'Organization',
    name: 'Deliver WMS',
    email: 'hello@deliverwms.com',
    url: 'https://deliverwms.com',
  },
};
---

<BaseLayout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Hero -->
  <section class="relative isolate overflow-hidden border-b border-slate-200 bg-white py-20 sm:py-24 dark:border-slate-800 dark:bg-slate-950">
    <div class="dot-grid-bg absolute inset-0 -z-10 opacity-50 [mask-image:radial-gradient(ellipse_at_center,white_30%,transparent_70%)]"></div>
    <div class="brand-glow -right-32 top-0 h-72 w-72"></div>

    <div class="container-narrow text-center">
      <p class="eyebrow mx-auto justify-center">Contact</p>
      <h1 class="display mt-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">Get in touch</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Book a demo, ask a question, or tell us about your operation. We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Form + info -->
  <section class="bg-slate-50 py-16 sm:py-20 dark:bg-slate-900/50">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-5">
        <!-- Info column -->
        <aside class="lg:col-span-2">
          <h2 class="font-display text-2xl font-bold tracking-tight">Let's discuss your logistics needs</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-400">
            Whether you're a 3PL running multi-client warehouses or a brand scaling DTC fulfillment, we can help you streamline operations.
          </p>

          <dl class="mt-8 space-y-6">
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Email</dt>
              <dd class="mt-1">
                <a href="mailto:hello@deliverwms.com" class="text-slate-900 hover:text-brand-700 dark:text-white dark:hover:text-brand-400">
                  hello@deliverwms.com
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Location</dt>
              <dd class="mt-1 text-slate-700 dark:text-slate-300">
                Remote-first team serving logistics operations worldwide.
              </dd>
            </div>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Response time</dt>
              <dd class="mt-1 text-slate-700 dark:text-slate-300">
                Most inquiries answered within one business day.
              </dd>
            </div>
          </dl>
        </aside>

        <!-- Form column -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 dark:border-slate-800 dark:bg-slate-900 lg:col-span-3">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

# Copy this to .env.local for local dev. In production, set these in Vercel project settings.

# Supabase (app-side project — used for form submissions only)
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key

# Cloudflare Turnstile (anti-bot widget on Contact form)
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# App subdomain for Log In / Sign Up CTAs
PUBLIC_APP_URL=https://app.deliverwms.com
